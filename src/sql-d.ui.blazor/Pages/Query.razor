@using SqlD.UI.Blazor.Shared.Components.RegistryList

@inherits QueryBase

@page "/query"

<div class="container-fluid mt-4 mb-4">
    <div class="row-fluid">
        <div class="col-12 overflow-auto">
            <RegistryList
                Registry="@Registry"
                @bind-ConnectedService="ConnectedService"
                NewServiceClick="RegistryList_NewServiceClick"
                ServiceIdentityClick="RegistryList_ServiceIdentityClick"
                ServiceSwaggerClick="RegistryList_ServiceSwaggerClick"
                ServiceConnectClick="RegistryList_ServiceConnectClick">
            </RegistryList>
        </div>
    </div>
</div>

